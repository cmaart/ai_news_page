---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageCredit from '../../components/ImageCredit.astro';
import Pruefband from '../../components/Pruefband.astro';
import DisclosureBox from '../../components/DisclosureBox.astro';
import Kurzfazit from '../../components/Kurzfazit.astro';
import OpenQuestions from '../../components/OpenQuestions.astro';
import ClaimList from '../../components/ClaimList.astro';
import MethodologyBox from '../../components/MethodologyBox.astro';
import SourceList from '../../components/SourceList.astro';
import CorrectionTimeline from '../../components/CorrectionTimeline.astro';
import RetractionBanner from '../../components/RetractionBanner.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import TextlaengeToggle from '../../components/TextlaengeToggle.astro';
import VariantKompakt from '../../components/VariantKompakt.astro';
import VariantStandard from '../../components/VariantStandard.astro';
import { GENERATION_MODE_LABELS } from '../../config/disclosure';
import {
  byNewest,
  COUNTRY_LABELS,
  formatDate,
  isBuilt,
  isListed,
  lastUpdated,
  TOPIC_LABELS,
} from '../../lib/articles';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.filter(isBuilt).map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { data } = article;
const { Content } = await render(article);

const articles = await getCollection('articles');
const related = articles
  .filter((a) => a.id !== article.id)
  .filter(isListed)
  .sort(byNewest)
  .slice(0, 3);

// Verwandte Artikel derselben Story (E53) — bidirektional gepflegte relatedSlugs;
// nur gebaute, nicht zurückgezogene Artikel verlinken.
const relatedStoryArticles = (data.relatedSlugs ?? [])
  .map((slug) => articles.find((a) => a.id === slug))
  .filter((a): a is (typeof articles)[number] => !!a && isListed(a) && a.id !== article.id);

// Der Bezug ist gerichtet: ein älterer verwandter Artikel ist „Vorgeschichte",
// ein jüngerer eine „Weitere Entwicklung". Richtung aus publishedAt ableiten
// (fehlt eines der Daten, als Vorgeschichte behandeln — der häufigere Fall).
const relatedGroups = [
  {
    label: 'Vorgeschichte',
    items: relatedStoryArticles.filter((a) => {
      const t = a.data.publishedAt?.getTime();
      const cur = data.publishedAt?.getTime();
      return t != null && cur != null ? t < cur : true;
    }),
  },
  {
    label: 'Weitere Entwicklung',
    items: relatedStoryArticles.filter((a) => {
      const t = a.data.publishedAt?.getTime();
      const cur = data.publishedAt?.getTime();
      return t != null && cur != null ? t >= cur : false;
    }),
  },
].filter((g) => g.items.length > 0);

const updated = lastUpdated(data);
const isRetracted = data.status === 'retracted';
const isArchived = data.status === 'archived';

const statusToCreativeWorkStatus: Record<string, string> = {
  published: 'Published',
  corrected: 'Corrected',
  retracted: 'Retracted',
  archived: 'Archived',
};

// OG-/JSON-LD-Bild: gebaute Asset-URL absolut auflösen (E44).
const ogImage = data.image
  ? await getImage({ src: data.image.file, width: 1200, format: 'jpeg' })
  : null;
const ogImageUrl = ogImage ? new URL(ogImage.src, Astro.site).toString() : undefined;

const publisher = {
  '@type': 'Organization',
  name: 'Neue Nachrichten',
  url: 'https://neuenachrichten.at/',
  logo: {
    '@type': 'ImageObject',
    url: new URL(withBase('/logo.png'), Astro.site).toString(),
    width: 512,
    height: 512,
  },
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: data.title,
  description: data.description,
  inLanguage: 'de-AT',
  ...(ogImageUrl && { image: [ogImageUrl] }),
  ...(data.publishedAt && { datePublished: data.publishedAt.toISOString() }),
  ...(updated && { dateModified: updated.toISOString() }),
  creativeWorkStatus: statusToCreativeWorkStatus[data.status] ?? data.status,
  author: publisher,
  publisher,
  mainEntityOfPage: new URL(withBase(`/artikel/${article.id}/`), Astro.site).toString(),
};
---

<BaseLayout
  title={`${data.title} · Neue Nachrichten`}
  description={data.description}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={ogImageUrl}
  noindex={isRetracted || isArchived}
>
  <article>
    <div class="article-head container-section">
      {
        isRetracted && data.retractionReason && (
          <div class="article-head__retraction">
            <RetractionBanner reason={data.retractionReason} />
          </div>
        )
      }

      <div class="article-head__eyebrow">
        <a href={withBase(`/themen/${data.topic}/`)}>{TOPIC_LABELS[data.topic]}</a>
        <span class="article-head__sep">·</span>
        {COUNTRY_LABELS[data.country]}
        {isArchived && <span class="badge">Archiviert</span>}
        {data.status === 'corrected' && <span class="badge badge--danger">Korrigiert</span>}
      </div>
      <h1 class="article-head__title">{data.title}</h1>
      <p class="article-head__standfirst">{data.description}</p>

      {
        relatedGroups.map((group) => (
          <aside class="article-head__vorgeschichte">
            <span class="article-head__vorgeschichte-label">{group.label}</span>
            <ul class="article-head__vorgeschichte-list">
              {group.items.map((a) => (
                <li>
                  <a href={withBase(`/artikel/${a.id}/`)}>{a.data.title}</a>
                </li>
              ))}
            </ul>
          </aside>
        ))
      }
      <div class="article-head__meta">
        {data.publishedAt && <span>Veröffentlicht {formatDate(data.publishedAt)}</span>}
        {data.updatedAt && <span>Aktualisiert {formatDate(data.updatedAt)}</span>}
        <span class="article-head__meta-ai">
          <span class="dot dot--accent article-head__ai-dot"></span>
          {GENERATION_MODE_LABELS[data.generationMode]}
        </span>
      </div>

      {
        data.image && (
          <figure class="article-hero">
            <Image
              src={data.image.file}
              alt={data.image.alt}
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 1024px) 100vw, 1024px"
              loading="eager"
            />
            <figcaption class="article-hero__caption">
              <span class="article-hero__text">
                {data.image.caption}
                {data.image.kind === 'symbol' && ' (Symbolbild)'}
              </span>
              <ImageCredit credit={data.image.credit} />
            </figcaption>
          </figure>
        )
      }

      <Pruefband data={data} />

      <div class="article-head__disclosure">
        <DisclosureBox
          generationMode={data.generationMode}
          editorialReview={data.editorialReview}
          note={data.aiDisclosureNote}
        />
      </div>

      <div class="article-head__kurzfazit">
        <Kurzfazit summary={data.summary} />
      </div>
    </div>

    <div class="article-body container-section">
      <TextlaengeToggle />
      <div class="prose">
        <Content components={{ Kompakt: VariantKompakt, Standard: VariantStandard }} />
      </div>
    </div>

    {
      data.openQuestions.length > 0 && (
        <section class="article-section container-section" id="unklar">
          <OpenQuestions questions={data.openQuestions} />
        </section>
      )
    }

    {
      data.claims.length > 0 && (
        <section class="article-section container-section">
          <h2 class="section-heading">Geprüfte Aussagen</h2>
          <ClaimList claims={data.claims} />
        </section>
      )
    }

    <section class="article-section container-section">
      <MethodologyBox data={data} />
    </section>

    <section class="article-section container-section" id="quellen">
      <h2 class="section-heading">Quellen</h2>
      <SourceList sources={data.sources} />
    </section>

    {
      data.corrections.length > 0 && (
        <section class="article-section container-section" id="korrekturen">
          <h2 class="section-heading">Korrekturen &amp; Updates</h2>
          <CorrectionTimeline corrections={data.corrections} />
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="article-related container-wide">
          <h2 class="section-heading">Weiterlesen</h2>
          <div class="article-related__grid">
            {related.map((a) => (
              <ArticleCard article={a} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .article-head {
    padding-top: 48px;
  }

  .article-head__retraction {
    margin-bottom: 32px;
  }

  .article-head__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }

  .article-head__eyebrow a {
    color: var(--accent);
  }

  .article-head__sep {
    color: var(--color-border-soft);
  }

  .article-head__title {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 44px;
    line-height: 1.12;
    letter-spacing: -0.015em;
  }

  .article-head__standfirst {
    margin: 0 0 20px;
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .article-head__vorgeschichte {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 12px;
    margin: 0 0 20px;
    padding: 12px 16px;
    border-left: 3px solid var(--accent);
    background: var(--color-bg-subtle, rgba(0, 0, 0, 0.03));
  }

  .article-head__vorgeschichte-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .article-head__vorgeschichte-list {
    margin: 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.4;
  }

  .article-head__vorgeschichte-list li + li {
    margin-top: 4px;
  }

  .article-head__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--color-text-faint);
    margin-bottom: 24px;
  }

  /* Hero fix 16:9 — Ausschnitt nur via object-fit, Datei bleibt ungecroppt (E44).
     Feste Ratio ist der Layout-Guard: auch ein untaugliches Bild sprengt die Seite nie. */
  .article-hero {
    margin: 0 0 28px;
  }

  .article-hero :global(img) {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    object-fit: cover;
  }

  .article-hero__caption {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 4px 16px;
    padding-top: 8px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 10px;
  }

  .article-hero__text {
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .article-head__meta-ai {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .article-head__ai-dot {
    width: 6px;
    height: 6px;
  }

  .article-head__disclosure {
    margin-top: 28px;
  }

  .article-head__kurzfazit {
    margin-top: 28px;
  }

  .article-body {
    padding-top: 40px;
  }

  .article-section {
    margin-top: 48px;
  }

  .article-related {
    margin-top: 72px;
  }

  .article-related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
    margin-top: 24px;
  }

  @media (max-width: 720px) {
    .article-head__title {
      font-size: 32px;
    }
  }
</style>
