---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Aufmacher from '../../components/Aufmacher.astro';
import { byNewest, byRelevance, isFresh, TOPIC_LABELS, TOPICS } from '../../lib/articles';
import type { Topic } from '../../lib/articles';

export async function getStaticPaths() {
  return TOPICS.map((topic) => ({ params: { topic } }));
}

const { topic } = Astro.params as { topic: Topic };
// Alters-Archiv (E54): Themen-Seite zeigt nur frische Artikel; Älteres über /archiv/.
const articles = (await getCollection('articles'))
  .filter(isFresh)
  .filter((a) => a.data.topic === topic)
  .sort(byNewest);
// Aufmacher = relevantester Artikel des Themas (E51); Grid darunter = übrige, chronologisch.
const [aufmacher] = [...articles].sort(byRelevance);
const rest = articles.filter((a) => a.id !== aufmacher?.id);
---

<BaseLayout title={`${TOPIC_LABELS[topic]} · Neue Nachrichten`}>
  <section class="topic container-wide">
    <p class="topic__eyebrow">Thema</p>
    <h1 class="topic__title">{TOPIC_LABELS[topic]}</h1>
    {
      aufmacher ? (
        <>
          <Aufmacher article={aufmacher} eager />
          {rest.length > 0 && (
            <div class="topic__grid">
              {rest.map((article) => (
                <ArticleCard article={article} />
              ))}
            </div>
          )}
        </>
      ) : (
        <p class="topic__empty">Noch keine veröffentlichten Artikel zu diesem Thema.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .topic {
    padding-top: 64px;
  }

  .topic__eyebrow {
    margin: 0 0 8px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .topic__title {
    margin: 0 0 32px;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 36px;
    letter-spacing: -0.015em;
  }

  .topic__grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
  }

  .topic__empty {
    color: var(--color-text-faint);
  }
</style>
