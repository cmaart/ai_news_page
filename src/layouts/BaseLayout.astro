---
import '@fontsource/spectral/400.css';
import '@fontsource/spectral/400-italic.css';
import '@fontsource/spectral/500.css';
import '@fontsource/spectral/600.css';
import '@fontsource/spectral/700.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

import Analytics from '../components/Analytics.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { GLOBAL_DISCLOSURE, SITE_CLAIM } from '../config/disclosure';
import { TOPICS, TOPIC_LABELS } from '../lib/articles';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  /** Zusätzliche strukturierte Daten (JSON-LD) der Seite. */
  jsonLd?: Record<string, unknown>;
  ogType?: 'website' | 'article';
  /** Absolute URL des Vorschaubilds (Artikel-Hero, E44). */
  ogImage?: string;
  noindex?: boolean;
}

const { title, description = SITE_CLAIM, jsonLd, ogType = 'website', ogImage, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const hasGa = Boolean(import.meta.env.PUBLIC_GA_ID);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="de-AT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <link rel="alternate" type="application/rss+xml" title="Neue Nachrichten" href={withBase('/rss.xml')} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Neue Nachrichten" />
    <meta property="og:locale" content="de_AT" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <Analytics />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner container-wide">
        <div class="site-header__brand">
          <a href={withBase('/')} class="site-header__logo">Neue Nachrichten</a>
          <span class="site-header__tagline">KI-gestützte Recherche · Offene Quellenlage</span>
        </div>
        <nav class="site-header__nav" aria-label="Hauptnavigation">
          <a href={withBase('/themen/')}>Themen</a>
          <a href={withBase('/methodik/')}>Methodik</a>
          <a href={withBase('/korrekturen/')}>Korrekturen</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__grid container-wide">
        <div class="site-footer__brand">
          <span class="site-footer__logo">Neue Nachrichten</span>
          <p class="site-footer__disclosure">{GLOBAL_DISCLOSURE}</p>
        </div>
        <div class="site-footer__col">
          <span class="site-footer__label">Themen</span>
          {TOPICS.map((topic) => <a href={withBase(`/themen/${topic}/`)}>{TOPIC_LABELS[topic]}</a>)}
        </div>
        <div class="site-footer__col">
          <span class="site-footer__label">Transparenz</span>
          <a href={withBase('/methodik/')}>Methodik</a>
          <a href={withBase('/korrekturen/')}>Korrekturen</a>
          <a href={withBase('/bildnachweis/')}>Bildnachweis</a>
          <a href={withBase('/rss.xml')}>RSS-Feed</a>
        </div>
        <div class="site-footer__col">
          <span class="site-footer__label">Rechtliches</span>
          <a href={withBase('/impressum/')}>Impressum</a>
          <a href={withBase('/datenschutz/')}>Datenschutz</a>
          {
            hasGa && (
              <a href={withBase('/datenschutz/')} data-cookie-settings>
                Cookie-Einstellungen
              </a>
            )
          }
        </div>
      </div>
      <div class="site-footer__copyright container-wide">
        © {year} Neue Nachrichten · KI-gestützt erstellte Inhalte · Nicht redaktionell geprüft, sofern nicht anders
        angegeben
      </div>
    </footer>

    <CookieBanner />
  </body>
</html>

<style>
  .site-header {
    background: rgba(251, 250, 247, 0.92);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-top: 14px;
    padding-bottom: 14px;
  }

  .site-header__brand {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .site-header__logo {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 27px;
    line-height: 1.15;
    letter-spacing: 0.005em;
    color: var(--color-ink);
  }

  .site-header__logo:hover {
    color: var(--color-ink);
    text-decoration: none;
  }

  .site-header__tagline {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--color-text-ghost);
  }

  .site-header__nav {
    display: flex;
    gap: 22px;
  }

  .site-header__nav a {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 80px;
    padding-top: 48px;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 32px;
    padding-bottom: 40px;
  }

  .site-footer__logo {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 18px;
  }

  .site-footer__disclosure {
    margin: 10px 0 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 420px;
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .site-footer__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-ghost);
    margin-bottom: 4px;
  }

  .site-footer__col a {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .site-footer__copyright {
    border-top: 1px solid var(--color-border);
    padding-top: 18px;
    padding-bottom: 24px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-text-ghost);
  }

  @media (max-width: 720px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .site-footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
