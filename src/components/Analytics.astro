---
/**
 * GA4 mit Consent Mode v2 und echtem Opt-in.
 * Default: alles denied. gtag.js wird erst nach Einwilligung geladen.
 * Ohne PUBLIC_GA_ID wird nichts gerendert (lokal/Preview).
 */
const gaId = import.meta.env.PUBLIC_GA_ID as string | undefined;
---

{
  gaId && (
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      window.gtag = gtag;
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
      gtag('js', new Date());

      window.__nnLoadGA = function () {
        gtag('consent', 'update', { analytics_storage: 'granted' });
        if (window.__nnGaLoaded) return;
        window.__nnGaLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(gaId);
        document.head.appendChild(s);
        gtag('config', gaId, { anonymize_ip: true });
      };
      window.__nnDenyGA = function () {
        gtag('consent', 'update', { analytics_storage: 'denied' });
      };

      if (localStorage.getItem('nn-consent') === 'granted') {
        window.__nnLoadGA();
      }
    </script>
  )
}
