---
import type { ArticleData } from '../lib/articles';

interface Props {
  summary: ArticleData['summary'];
}

const { summary } = Astro.props;
---

<aside class="kurzfazit" aria-label="Kurzfazit">
  <span class="kurzfazit__label">Kurzfazit</span>
  <ul class="kurzfazit__list">
    {
      summary.map((item) => (
        <li class:list={['kurzfazit__item', `kurzfazit__item--${item.kind}`]}>
          <span class="kurzfazit__marker">{item.kind === 'fact' ? '✓' : '?'}</span>
          {item.text}
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .kurzfazit {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 26px 30px;
  }

  .kurzfazit__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin-bottom: 14px;
  }

  .kurzfazit__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .kurzfazit__item {
    position: relative;
    padding-left: 26px;
    margin-bottom: 10px;
    font-family: var(--font-serif);
    font-size: 16.5px;
    line-height: 1.5;
    color: var(--color-ink-soft);
  }

  .kurzfazit__item:last-child {
    margin-bottom: 0;
  }

  .kurzfazit__marker {
    position: absolute;
    left: 0;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--accent);
  }

  .kurzfazit__item--open .kurzfazit__marker {
    color: var(--warn-alt);
  }
</style>
